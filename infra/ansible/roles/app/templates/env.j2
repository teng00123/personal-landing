# {{ ansible_managed }}
# .env template for {{ deploy_env }}

DEBUG=false
APP_SECRET_KEY={{ app_secret_key }}
ALLOWED_ORIGINS={{ allowed_origins }}

DB_HOST={{ db_host | default('db') }}
DB_PORT={{ db_port | default(3306) }}
DB_USER={{ db_user }}
DB_PASSWORD={{ db_password }}
DB_NAME={{ db_name | default('personal_homepage') }}

REDIS_HOST={{ redis_host | default('redis') }}
REDIS_PORT={{ redis_port | default(6379) }}

CELERY_BROKER_URL=redis://{{ redis_host | default('redis') }}:6379/1
CELERY_RESULT_BACKEND=redis://{{ redis_host | default('redis') }}:6379/2

GITHUB_TOKEN={{ github_token | default('') }}
ADMIN_USERNAME={{ admin_username | default('admin') }}
ADMIN_EMAIL={{ admin_email }}
ADMIN_PASSWORD={{ admin_password }}
