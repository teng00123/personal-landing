{
  "title": "Personal Landing - Overview",
  "uid": "pl-overview",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "RPS (请求/秒)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(http_requests_total[1m]))",
        "legendFormat": "RPS"
      }]
    },
    {
      "id": 2, "type": "stat", "title": "错误率",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(http_requests_total{status_code=~'5..'}[5m])) / sum(rate(http_requests_total[5m])) * 100",
        "legendFormat": "Error %"
      }]
    },
    {
      "id": 3, "type": "stat", "title": "P95 响应时间",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le)) * 1000",
        "legendFormat": "P95 ms"
      }]
    },
    {
      "id": 4, "type": "stat", "title": "文章总阅读量",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "article_views_total",
        "legendFormat": "Views"
      }]
    },
    {
      "id": 5, "type": "timeseries", "title": "HTTP 请求速率",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~'2..'}[1m]))",
          "legendFormat": "2xx"
        },
        {
          "expr": "sum(rate(http_requests_total{status_code=~'4..'}[1m]))",
          "legendFormat": "4xx"
        },
        {
          "expr": "sum(rate(http_requests_total{status_code=~'5..'}[1m]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "id": 6, "type": "timeseries", "title": "响应时间分布",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "id": 7, "type": "timeseries", "title": "CPU 使用率",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)",
        "legendFormat": "CPU %"
      }]
    },
    {
      "id": 8, "type": "timeseries", "title": "内存使用率",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
        "legendFormat": "Memory %"
      }]
    }
  ]
}