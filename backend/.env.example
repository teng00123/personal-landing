# ── App ───────────────────────────────────────────────────
APP_SECRET_KEY=change-me-use-openssl-rand-hex-32
DEBUG=false
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS（生产环境改为你的真实域名）─────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost

# ── MySQL ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=app
DB_PASSWORD=apppass
DB_NAME=personal_homepage

# ── Redis ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── Celery ─────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── GitHub（可选，提升 API 限速上限）────────────────────
GITHUB_TOKEN=

# ── 项目部署 ───────────────────────────────────────────────
DEPLOY_BASE_DIR=./deploy_workspace
DEPLOY_BASE_PORT=8100
# 部署后的访问基础 URL（改为你的域名或公网 IP）
DEPLOY_BASE_URL=http://localhost

# ── 管理员初始账号（init_db.py 使用）────────────────────
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123456
